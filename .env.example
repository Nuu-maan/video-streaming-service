# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=30s

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=video_streaming
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

# Storage Configuration
STORAGE_UPLOAD_PATH=./web/uploads
STORAGE_THUMBNAIL_PATH=./web/uploads/thumbnails
STORAGE_TRANSCODED_PATH=./web/uploads/transcoded
STORAGE_MAX_FILE_SIZE=2147483648

# Worker Configuration
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_JOB_TIMEOUT=30m

# FFmpeg Configuration (optional - auto-detected from PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_THREADS=2

# Quality Settings
ENABLE_360P=true
ENABLE_480P=true
ENABLE_720P=true
ENABLE_1080P=true
DELETE_ORIGINAL_AFTER_PROCESSING=false

# HLS Configuration
HLS_SEGMENT_DURATION=6
HLS_PLAYLIST_TYPE=vod
ENABLE_HLS=true
HLS_CACHE_TTL=3600

# Streaming Configuration
MAX_BANDWIDTH=10000000
MIN_BANDWIDTH=500000

# Logging
LOG_LEVEL=info

# Search Configuration
ENABLE_AUTOCOMPLETE=true
AUTOCOMPLETE_MIN_CHARS=2
MAX_SEARCH_RESULTS=50
SEARCH_CACHE_TTL=300

# Recommendation Configuration
RECOMMENDATION_CACHE_TTL=3600
TRENDING_UPDATE_INTERVAL=600
PERSONALIZED_FEED_SIZE=20
RECOMMENDATION_SIMILARITY_THRESHOLD=0.3

# Social Features Configuration
MAX_COMMENT_LENGTH=10000
ENABLE_COMMENT_REPLIES=true
MAX_PLAYLIST_VIDEOS=500
WATCH_HISTORY_RETENTION_DAYS=365
MAX_SUBSCRIPTIONS_PER_USER=1000

# Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
BATCH_NOTIFICATIONS=true
NOTIFICATION_BATCH_WINDOW=3600
NOTIFICATION_CACHE_TTL=60

# MinIO Object Storage Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=videos-raw
MINIO_BUCKET_PROCESSED=videos-processed
MINIO_BUCKET_THUMBS=thumbnails

# CDN / Nginx Configuration
CDN_ENABLED=true
CDN_BASE_URL=http://localhost
CDN_CACHE_TTL=2592000
NGINX_VIDEO_CACHE_SIZE=10g
NGINX_THUMB_CACHE_SIZE=2g

# Performance Tuning
ENABLE_L1_CACHE=true
L1_CACHE_SIZE=10000
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10

# Rate Limiting
RATE_LIMIT_GUEST=30
RATE_LIMIT_USER=60
RATE_LIMIT_PREMIUM=300
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_SEARCH=30

# Video Processing Optimization
FFMPEG_PRESET=medium
ENABLE_TWO_PASS=false
ENABLE_HARDWARE_ACCEL=false
MAX_CONCURRENT_TRANSCODING=3

# Monitoring
ENABLE_METRICS=true
METRICS_PATH=/metrics
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Connection Pooling
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# Request Settings
REQUEST_TIMEOUT=60s
MAX_UPLOAD_SIZE=2147483648
ENABLE_GZIP=true
