# Every key below is read by internal/config. Nothing else is.
#
# The previous version of this file declared roughly twenty keys that no code
# ever loaded (FFMPEG_PATH, ENABLE_HLS, HLS_SEGMENT_DURATION, the search,
# recommendation, notification and CDN blocks), which made them look
# configurable when they were inert. They have been removed rather than left
# to mislead. Behaviour that is genuinely hardcoded today — the transcoding
# ladder, HLS segment length — lives in internal/service/transcoding_service.go.

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=30s
# Comma-separated IPs or CIDR ranges whose X-Forwarded-For is believed. Empty
# means trust no proxy: client IPs then come from the TCP connection, which
# cannot be spoofed. Behind the compose nginx, set this to the compose network
# range (e.g. 172.16.0.0/12) or rate limiting will key every request to nginx's
# address — and leaving it wider than your proxies lets clients forge their IP.
SERVER_TRUSTED_PROXIES=
LOG_LEVEL=info

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=video_streaming
# Refused in production: set to require/verify-full when ENVIRONMENT=production.
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

# ---- Authentication ----
# Generate one with: openssl rand -base64 48
# The default below is a known development value. Booting with ENVIRONMENT=production
# while this is unset is a hard config error, not a warning.
JWT_SECRET=dev-only-insecure-jwt-secret-change-me
JWT_ISSUER=video-streaming-service
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
# What to do when Redis (the token-revocation store) is unreachable. false
# rejects authenticated requests with 503 until it returns; true accepts them,
# which means logout/revocation is silently unenforced during the outage.
AUTH_REVOCATION_FAIL_OPEN=false

# ---- CORS ----
# Comma-separated. "*" is rejected in production: the API sends credentials, and
# wildcard-plus-credentials is both refused by browsers and unsafe.
CORS_ALLOWED_ORIGINS=http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Authorization, Content-Type and Range are always granted even if omitted
# here — without them the API cannot be consumed cross-origin at all.
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,Range
CORS_MAX_AGE=12h

# ---- Storage (local filesystem) ----
STORAGE_UPLOAD_PATH=./web/uploads
STORAGE_THUMBNAIL_PATH=./web/uploads/thumbnails
STORAGE_TRANSCODED_PATH=./web/uploads/transcoded
STORAGE_MAX_FILE_SIZE=2147483648
STORAGE_ALLOWED_FORMATS=video/mp4,video/mpeg,video/quicktime,video/webm,video/x-matroska

# ---- Object storage (MinIO) ----
# Off by default: the transcoding pipeline still reads and writes the local
# filesystem. Turning this on requires credentials.
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=videos-raw
MINIO_BUCKET_PROCESSED=videos-processed
MINIO_BUCKET_THUMBNAILS=videos-thumbnails

# ---- Rate limiting ----
# Enforced in the API process. The limit_req rules in nginx.conf do not apply to
# the API, because nginx only ever proxies MinIO.
RATE_LIMIT_ENABLED=true

# ---- Email ----
# Empty SMTP_HOST means no mail server: outgoing mail (verification links,
# password resets) is written to the application log instead of sent, so local
# development needs no SMTP setup.
SMTP_HOST=
# 465 is implicit TLS; every other port negotiates STARTTLS.
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Permit cleartext delivery when the server offers no STARTTLS. Local relays
# (MailHog) only; refused outright when ENVIRONMENT=production.
SMTP_ALLOW_INSECURE=false
MAIL_FROM=no-reply@localhost
# The FRONTEND origin mailed links point at ({base}/verify-email?token=... and
# {base}/reset-password?token=...) — the separate frontend project's address,
# never this API's own.
MAIL_FRONTEND_BASE_URL=http://localhost:3000
# How long a password-reset link stays usable.
MAIL_PASSWORD_RESET_TTL=1h

# ---- Worker ----
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_JOB_TIMEOUT=30m

# ---- Hosting / deployment ----
# The keys in THIS section are read by docker-compose.prod.yml and the nginx
# front proxy, NOT by internal/config. Everything above is passed into the api
# and worker containers verbatim via env_file; the compose file itself only
# overrides service hostnames (DB_HOST=postgres, REDIS_HOST=redis,
# MINIO_ENDPOINT=minio:9000) and the STORAGE_* paths (/data/uploads).
#
# Notes for a real deployment:
#   * DB_PASSWORD is interpolated into a connection URL by the migrate
#     service — percent-encode @ : / ? # if they appear in it.
#   * ENVIRONMENT=production makes config validation refuse DB_SSLMODE=disable
#     and the default JWT_SECRET. Inside the compose network Postgres has no
#     TLS by default, so either configure Postgres with certificates and set
#     DB_SSLMODE=require, or keep ENVIRONMENT=development until you do.
#   * Set CORS_ALLOWED_ORIGINS to your frontend origin(s), e.g.
#     https://app.example.com — the API is consumed cross-origin.

# Host port nginx publishes. TLS termination is out of scope for the compose
# file; put a TLS-terminating proxy or load balancer in front of this port.
NGINX_HTTP_PORT=80
